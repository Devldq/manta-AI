{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["./src/*"],
      "@storage/*": ["./src/storage/*"],
      "@tools/*": ["./src/tools/*"],
      "@security/*": ["./src/security/*"],
      "@/core/*": ["./src/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "src/types.ts",
    "src/index.ts",
    "src/storage/**/*.ts",
    "src/services/**/*.ts",
    "src/api/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*.bak"]
}
