{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./src/app/*"],
      "@core/*": ["./src/core/*"],
      "@registry/*": ["./src/registry/*"],
      "@engine/*": ["./src/core/engine/*"],
      "@context/*": ["./src/core/context/*"],
      "@storage/*": ["./src/core/storage/*"],
      "@tools/*": ["./src/core/tools/*"],
      "@observability/*": ["./src/core/observability/*"],
      "@security/*": ["./src/core/security/*"],
      "@llm/*": ["./src/core/llm/*"],
      "@design/*": ["./design/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
