{
  "name": "manta",
  "version": "2.0.0",
  "private": true,
  "author": "lidaqing",
  "description": "Manta — Agent 调度操作系统 · Humans steer. Agents execute. Drivers are pluggable.",
  "scripts": {
    "dev": "pnpm exec turbo run dev --filter=@manta/shared --filter=@manta/backend --filter=@manta/frontend",
    "dev:fe": "pnpm exec turbo run dev --filter=@manta/frontend",
    "dev:be": "pnpm exec turbo run dev --filter=@manta/backend",
    "dev:desktop": "pnpm exec turbo run dev --filter=@manta/desktop",
    "build": "pnpm exec turbo run build --filter=@manta/shared --filter=@manta/backend --filter=@manta/frontend",
    "build:docker": "docker compose -f docker/docker-compose.yml build",
    "start:docker": "docker compose -f docker/docker-compose.yml up",
    "start": "pnpm --filter @manta/backend start",
    "typecheck": "pnpm exec turbo run typecheck --filter=@manta/shared --filter=@manta/backend --filter=@manta/frontend",
    "lint": "pnpm exec turbo run lint",
    "clean": "pnpm exec turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@parcel/watcher",
      "esbuild",
      "bufferutil",
      "utf-8-validate"
    ]
  }
}
