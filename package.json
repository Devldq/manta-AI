{
  "name": "manta",
  "version": "2.0.0",
  "private": true,
  "main": "src/electron/main.js",
  "author": "lidaqing",
  "description": "Manta — Agent 调度操作系统 · Humans steer. Agents execute. Drivers are pluggable.",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@manta/web",
    "dev:server": "turbo dev --filter=@manta/server",
    "dev:desktop": "turbo dev --filter=@manta/desktop",
    "build": "turbo build",
    "build:web": "turbo build --filter=@manta/web",
    "build:server": "turbo build --filter=@manta/server",
    "build:desktop": "turbo build --filter=@manta/desktop",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5",
    "wait-on": "^9.0.4",
    "yaml": "^2.8.3"
  }
}
