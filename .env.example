# ARM_DATA_ROOT 配置本机数据目录，默认 ~/arm-data
ARM_DATA_ROOT=

# ─── Electron 端口配置 ───────────────────────────────────────────────────────
# 指定 Next.js 服务器端口（可选），默认使用随机端口避免冲突
# 如果端口3000被占用，构建的DMG在其他电脑上可能会白屏
# ELECTRON_NEXT_PORT=3000

# ─── LangChain 聊天配置 ──────────────────────────────────────────────────────
#
# 方式 1: OpenAI API
# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
#
# 方式 2: OpenAI 兼容接口（DeepSeek、通义千问、Moonshot、kimi 等）
# AI_API_KEY=your-api-key
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
#
# 方式 3: 本地 Ollama（无需 API Key）
# AI_BASE_URL=http://localhost:11434
# AI_MODEL=llama3.2
#
# 方式 4: LM Studio（无需 API Key）
# AI_BASE_URL=http://localhost:1234/v1
# AI_MODEL=local-model
#
# 同时也支持 OPENAI_* 前缀：
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# 优先级：Settings UI 配置 > 环境变量
# 可在应用 Settings > AI 模型 Tab 进行 UI 配置并测试连接
