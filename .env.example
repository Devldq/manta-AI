# ARM_DATA_ROOT 配置本机数据目录，默认 ~/arm-data
ARM_DATA_ROOT=

# AI 润色功能配置（可选 - 如果不配置则自动使用 OpenClaw）
# 
# 方式 1: 零配置（推荐）
# 直接使用本地 OpenClaw CLI，无需任何配置！
# 确保已安装: brew install openclaw
#
# 方式 2: 使用外部 OpenAI 兼容接口（更快速度）
# 可使用 OPENAI_* 或 AI_* 前缀的环境变量
# AI_API_KEY=your-api-key-here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# 或者使用 OPENAI 前缀
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 智能降级策略:
# - 有外部 API Key → 使用外部 API（速度更快）
# - 无外部 API Key → 自动使用 OpenClaw（零配置）
# - 完全自动化，对用户透明
