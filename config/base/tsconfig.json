{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./src/app/*"],
      "@core/*": ["./src/core/*"],
      "@registry/*": ["./src/registry/*"],
      "@engine/*": ["./src/core/engine/*"],
      "@context/*": ["./src/core/context/*"],
      "@storage/*": ["./src/core/storage/*"],
      "@tools/*": ["./src/core/tools/*"],
      "@observability/*": ["./src/core/observability/*"],
      "@security/*": ["./src/core/security/*"],
      "@llm/*": ["./src/core/llm/*"],
      "@design/*": ["./design/*"]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
