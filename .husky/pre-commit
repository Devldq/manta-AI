#!/usr/bin/env bash
# AI: Git pre-commit 钩子 — 提交前安全检查（敏感信息检测）
# 参考 v1 实现，检查快手相关内容、API密钥、私钥等敏感信息

set -e

# 检查 Node.js 环境
if ! command -v node &> /dev/null; then
  echo "⚠️  警告: 未找到 Node.js，跳过敏感信息检查"
  exit 0
fi

# 检查配置文件是否存在
CONFIG_FILE="config/sensitive-rules.yaml"
SCRIPT_FILE="scripts/sensitive-check.ts"

if [ ! -f "$CONFIG_FILE" ]; then
  echo "⚠️  未找到配置文件: $CONFIG_FILE"
  echo "跳过敏感信息检查"
  exit 0
fi

if [ ! -f "$SCRIPT_FILE" ]; then
  echo "⚠️  未找到检查脚本: $SCRIPT_FILE"
  echo "跳过敏感信息检查"
  exit 0
fi

# 执行敏感信息检查
echo "🔍 执行安全检查..."
if command -v npx &> /dev/null; then
  npx tsx "$SCRIPT_FILE"
else
  node --loader ts-node/esm "$SCRIPT_FILE" 2>/dev/null || {
    echo "⚠️  无法执行 TypeScript 脚本，跳过检查"
    exit 0
  }
fi
